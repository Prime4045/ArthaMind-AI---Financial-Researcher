# Automated Financial Research Platform Configuration
# Rename this file to '.env' and fill in your keys.

# xAI Grok API Key (Preferred)
# Get a key from: https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here

# Alternative API Keys (Fallbacks)
# GROQ_API_KEY=your_groq_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here

# Backend configuration (optional)
PORT=8000
HOST=127.0.0.1
DATABASE_URL=sqlite:///./backend/financial_research.db
